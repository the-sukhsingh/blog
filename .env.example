# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Environment variable template for the Blog CMS
#
# USAGE:
#   cp .env.example .env
#   Edit the values marked with ← CHANGE THIS
#
# This file is safe to commit. The actual .env file must NOT be committed.
# ══════════════════════════════════════════════════════════════════════════════

# ── Next.js / NextAuth ────────────────────────────────────────────────────────

# Random secret for signing JWT session tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here  # ← CHANGE THIS

# The public URL of your Next.js app (used by NextAuth for callbacks).
# Local Docker:  http://localhost:3000
# Production:    https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Password for the 'postgres' superuser (used by all Supabase services).
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=your-super-secret-postgres-password  # ← CHANGE THIS

# Internal Docker connection string used by Prisma.
# Points to the 'db' service on the internal Docker network.
DATABASE_URL=postgresql://postgres:your-super-secret-postgres-password@db:5432/postgres

# For cloud deployments (Vercel, Railway), replace with your hosted DB URL:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres


# ── Supabase JWT ──────────────────────────────────────────────────────────────
# All three values must be consistent with each other.

# The master secret used to sign all Supabase JWTs.
# Must be at least 32 characters.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long  # ← CHANGE THIS

JWT_EXPIRY=3600

# The anon (public) key — a JWT with payload: {"role":"anon","iss":"supabase"}
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Or use the helper: docker compose run --rm app node /app/docker/generate-keys.js
SUPABASE_ANON_KEY=your-anon-key-here  # ← CHANGE THIS

# The service role (admin) key — a JWT with payload: {"role":"service_role","iss":"supabase"}
# ⚠️ Keep this secret — it bypasses all Row Level Security policies.
SUPABASE_SERVICE_KEY=your-service-role-key-here  # ← CHANGE THIS


# ── Supabase URLs ─────────────────────────────────────────────────────────────

# Internal Docker URL — used by the Next.js server to call Supabase APIs
# (routes through Kong on the internal Docker network).
# Local Docker:  http://kong:8000
# Cloud:         https://<project-ref>.supabase.co
SUPABASE_URL=http://kong:8000

# Public URL — used to construct image URLs visible to browsers.
# Must be reachable from outside Docker (the host machine / internet).
# Local Docker:  http://localhost:8000
# Production VPS: http://<your-server-ip>:8000  or  https://storage.yourdomain.com
# Cloud:          https://<project-ref>.supabase.co  (same as SUPABASE_URL)
SUPABASE_STORAGE_PUBLIC_URL=http://localhost:8000

# Name of the storage bucket for uploaded media.
SUPABASE_BUCKET=blog-media


# ── Supabase Internal Config (self-hosted only) ───────────────────────────────
# These are used by the Supabase service containers.
# Cloud deployments do not need these.

POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres

# Site URL passed to GoTrue (auth service)
SITE_URL=http://localhost:3000

# External API URL (Kong's public-facing URL)
API_EXTERNAL_URL=http://localhost:8000

# GoTrue (auth service) settings
# Since we use NextAuth, Supabase auth features are disabled.
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=false
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
JWT_EXPIRY=3600
ADDITIONAL_REDIRECT_URLS=
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/recover
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# SMTP (optional — only needed if you enable email features in GoTrue)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Blog CMS
LOG_LEVEL=error

# PostgREST
PGRST_DB_SCHEMAS=public,storage

# Vercel Blob (legacy — not currently used by this app)
BLOB_READ_WRITE_TOKEN=
