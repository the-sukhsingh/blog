generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(EDITOR)
  posts        Post[]
  createdAt    DateTime @default(now())
}

model Post {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  content      Json
  contentText  String     @default("")
  excerpt      String?
  coverImage   String?
  bgColorLight String?
  bgColorDark  String?
  status       PostStatus @default(DRAFT)
  author       User       @relation(fields: [authorId], references: [id])
  authorId     String
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId   String?
  tags         Tag[]
  comments     Comment[]
  allowComments Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  publishedAt  DateTime?

  @@index([slug])
  @@index([status, publishedAt])
}

model Category {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  bgColorLight String?
  bgColorDark  String?
  posts        Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  posts Post[]
}

model Comment {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  name      String
  email     String
  content   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}